generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// CAMPAIGN & EVENT
model Campaign {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  tagline     String        @default("Inspire It. Dream It. Do It.")
  state       CampaignState @default(PRE_LAUNCH)
  heroImageUrl String?
  startDate   DateTime?
  endDate     DateTime?
  config      Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  eventDays   EventDay[]
}

enum CampaignState {
  PRE_LAUNCH
  LAUNCH
  SCREENING
  LIVE
  POST_EVENT
}

model EventDay {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  dayNumber  Int
  date       DateTime
  label      String
  matches    Match[]
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  address String?
  mapUrl  String?
  pitches Pitch[]
}

model Pitch {
  id      String  @id @default(cuid())
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id])
  name    String
  label   String?
  matches Match[]
}

// TEAMS & PLAYERS
model Team {
  id           String   @id @default(cuid())
  name         String
  shortName    String?
  logoUrl      String?
  primaryColor String?
  groupId      String?
  group        Group?   @relation(fields: [groupId], references: [id])
  captainId    String?  @unique
  captain      User?    @relation("TeamCaptain", fields: [captainId], references: [id])
  seed         Int?
  bio          String?
  source       String?
  createdAt    DateTime @default(now())

  players      Player[]
  homeMatches  Match[]  @relation("HomeTeam")
  awayMatches  Match[]  @relation("AwayTeam")
  standings    Standing[]
  bracketTeams BracketNode[] @relation("BracketTeam")
  bracketWins  BracketNode[] @relation("BracketWinner")
  favorites    FavoriteTeam[]
}

model Player {
  id        String  @id @default(cuid())
  teamId    String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  position  String?
  number    Int?
  photoUrl  String?
  isCaptain Boolean @default(false)
  rosterEntry RosterMember?
}

// GROUPS & STANDINGS
model Group {
  id        String     @id @default(cuid())
  name      String
  order     Int        @default(0)
  teams     Team[]
  standings Standing[]
  matches   Match[]
}

model Standing {
  id             String   @id @default(cuid())
  groupId        String
  group          Group    @relation(fields: [groupId], references: [id])
  teamId         String
  team           Team     @relation(fields: [teamId], references: [id])
  played         Int      @default(0)
  won            Int      @default(0)
  drawn          Int      @default(0)
  lost           Int      @default(0)
  goalsFor       Int      @default(0)
  goalsAgainst   Int      @default(0)
  goalDifference Int      @default(0)
  points         Int      @default(0)
  position       Int      @default(0)
  lastUpdated    DateTime @default(now())

  @@unique([groupId, teamId])
  @@index([groupId, position])
}

// MATCHES & SCORES
model Match {
  id          String      @id @default(cuid())
  eventDayId  String?
  eventDay    EventDay?   @relation(fields: [eventDayId], references: [id])
  groupId     String?
  group       Group?      @relation(fields: [groupId], references: [id])
  pitchId     String?
  pitch       Pitch?      @relation(fields: [pitchId], references: [id])
  homeTeamId  String?
  homeTeam    Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String?
  awayTeam    Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  matchNumber Int?
  stage       MatchStage  @default(GROUP)
  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  score       Score?
  events      MatchEvent[]

  @@index([status])
  @@index([stage])
  @@index([scheduledAt])
}

enum MatchStage {
  GROUP
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE_FIRST_HALF
  HALF_TIME
  LIVE_SECOND_HALF
  FULL_TIME
  PENALTIES
  COMPLETED
  POSTPONED
  CANCELLED
}

model Score {
  id            String @id @default(cuid())
  matchId       String @unique
  match         Match  @relation(fields: [matchId], references: [id])
  homeGoals     Int    @default(0)
  awayGoals     Int    @default(0)
  homePenalties Int?
  awayPenalties Int?
  updatedAt     DateTime @updatedAt
}

model MatchEvent {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type       String
  minute     Int
  teamSide   String
  playerName String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([matchId, minute])
}

// KNOCKOUT BRACKET
model BracketNode {
  id           String     @id @default(cuid())
  stage        MatchStage
  position     Int
  teamId       String?
  team         Team?      @relation("BracketTeam", fields: [teamId], references: [id])
  winnerId     String?
  winner       Team?      @relation("BracketWinner", fields: [winnerId], references: [id])
  matchId      String?
  parentNodeId String?
  label        String?
  createdAt    DateTime   @default(now())

  @@index([stage, position])
}

// ZONE
model ZoneSchedule {
  id          String     @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  status      ZoneStatus @default(UPCOMING)
  category    String?
  capacity    Int?
  order       Int        @default(0)
}

enum ZoneStatus {
  UPCOMING
  ACTIVE
  PAUSED
  COMPLETED
}

// PRIZE
model PrizePackage {
  id          String @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  value       String?
  tier        String
  order       Int    @default(0)
}

// HIGHLIGHTS
model Highlight {
  id           String   @id @default(cuid())
  title        String
  description  String?
  mediaUrl     String
  mediaType    String   @default("video")
  thumbnailUrl String?
  matchId      String?
  category     String?
  order        Int      @default(0)
  publishedAt  DateTime @default(now())
}

// FAQ
model FaqItem {
  id       String  @id @default(cuid())
  question String
  answer   String
  category String?
  order    Int     @default(0)
}

// AUTH & USERS
model User {
  id         String   @id @default(cuid())
  phone      String   @unique
  name       String?
  email      String?
  avatarUrl  String?
  role       UserRole @default(FAN)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team           Team?            @relation("TeamCaptain")
  captainProfile CaptainProfile?
  applications   Application[]
  notifications  Notification[]
  preferences    NotificationPreference[]
  favorites      FavoriteTeam[]
  otpCodes       OtpCode[]
}

enum UserRole {
  FAN
  CAPTAIN
  ADMIN
  SUPER_ADMIN
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, code])
}

model CaptainProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  fullName     String
  email        String
  teamName     String
  area         String?
  experience   String?
  source       String?
  sourceDetail String?
}

// APPLICATION FLOW
model Application {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  status     ApplicationStatus @default(SUBMITTED)
  teamName   String
  formData   Json
  notes      String?
  reviewedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  statusLogs ApplicationStatusLog[]
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  RESERVE
  CONFIRMED
  NOT_SELECTED
}

model ApplicationStatusLog {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  changedBy     String?
  reason        String?
  createdAt     DateTime           @default(now())
}

// CAPTAIN MANAGEMENT
model RosterMember {
  id          String  @id @default(cuid())
  playerId    String  @unique
  player      Player  @relation(fields: [playerId], references: [id])
  teamId      String
  name        String
  position    String?
  number      Int?
  kitSize     String?
  isConfirmed Boolean @default(false)
}

model KitSizeSubmission {
  id          String   @id @default(cuid())
  teamId      String
  submittedBy String
  sizes       Json
  isComplete  Boolean  @default(false)
  submittedAt DateTime @default(now())
}

model AgreementStatus {
  id            String    @id @default(cuid())
  userId        String
  agreementType String
  accepted      Boolean   @default(false)
  acceptedAt    DateTime?
  ipAddress     String?
}

// NOTIFICATIONS
model NotificationTemplate {
  id       String @id @default(cuid())
  key      String @unique
  title    String
  body     String
  category String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category String
  enabled  Boolean @default(true)

  @@unique([userId, category])
}

model FavoriteTeam {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

// HERO SLIDES (CMS)
model HeroSlide {
  id            String  @id @default(cuid())
  backgroundUrl String
  tag           String?
  title1        String
  title2        String
  description   String
  ctaText       String?
  ctaHref       String?
  cta2Text      String?
  cta2Href      String?
  accent        String  @default("tcl-red")
  order         Int     @default(0)
  isActive      Boolean @default(true)
}

// SITE CONTENT (CMS key-value store)
model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text")
}
